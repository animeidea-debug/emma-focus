# Pushover 凭证（NAS Task App）
# 复制此文件为 .env 并填入实际值
# 注意：.env 已加入 .gitignore，不会提交到 git
# 
# 如何获取：
#   1. 在 pushover.net 注册账号
#   2. 创建一个 Application（Token）
#   3. 获取你的 User Key
#
# 填入后保存为 .env（与 notify.sh 同目录）即可生效
export PUSHOVER_NAS_TOKEN="your_pushover_app_token_here"
export PUSHOVER_NAS_USER="your_pushover_user_key_here"